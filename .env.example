# ── PUBLIC ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── SERVER ONLY (never expose to browser) ─────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron protection — generate with: openssl rand -hex 32
CRON_SECRET=

# AI Gateway
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_MODEL_PRIMARY=anthropic/claude-sonnet-4.6
AI_MODEL_FAST=anthropic/claude-haiku-4.5
AI_MODEL_FALLBACK=openai/gpt-5.4

# Webhook secrets — signature verification only, no provider tokens here
HUBSPOT_WEBHOOK_SECRET=
INSTANTLY_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=

# ── EXPLICITLY EXCLUDED ───────────────────────────────────────────────────────
# The following keys must NOT appear in this repo's environment at any time.
# They live exclusively in the Python worker repo:
#   APOLLO_API_KEY
#   CLAY_API_KEY
#   HUBSPOT_ACCESS_TOKEN
#   INSTANTLY_API_KEY
